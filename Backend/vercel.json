{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "artisan",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "https://ccs-department-profiling.vercel.app",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "mysql.railway.internal",
    "DB_PORT": "3306",
    "DB_DATABASE": "railway",
    "DB_USERNAME": "root",
    "DB_PASSWORD": "hdNZTazUeLrLUWXsnWdcWiPdtTsOlHjC",
    "FRONTEND_URL": "https://ccs-department-profiling.vercel.app"
  }
}
